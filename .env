# Chat server port
CHAT_SERVER_PORT=3001

# Laravel API (for storing messages and auth)
# Local Testing
LARAVEL_API_URL=http://localhost:8000
# Production Live
# LARAVEL_API_URL=https://news.preciousconsultant.com

# Redis (for Socket.IO adapter - horizontal scaling)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate limit: max messages per user per window
CHAT_RATE_LIMIT_MAX=5
CHAT_RATE_LIMIT_WINDOW_MS=10000

# Max message length (must match Laravel validation)
CHAT_MESSAGE_MAX_LENGTH=5000

# AI moderation (analyze every message before broadcast)
OPENAI_API_KEY=your_openai_api_key_here
AI_MODERATION_TIMEOUT_MS=8000
# Optional: block message if risk >= threshold (e.g. 0.8)
# AI_BLOCK_MISINFORMATION_THRESHOLD=0.8
# AI_BLOCK_TOXICITY_THRESHOLD=0.9
